{
  "name": "tmesh",
  "version": "0.1.0",
  "description": "tmux-native agent mesh. Zero-polling push communication for AI agents.",
  "type": "module",
  "main": "src/tmesh.ts",
  "bin": {
    "tmesh": "src/cli.ts"
  },
  "scripts": {
    "test": "bun test",
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "build:binary": "bun build src/cli.ts --compile --outfile dist/tmesh",
    "tmesh": "bun run src/cli.ts"
  },
  "license": "MIT",
  "keywords": [
    "tmux",
    "mesh",
    "agent",
    "ipc",
    "cli",
    "ai-agents",
    "push",
    "zero-polling"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sparklingslop/tmesh"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
